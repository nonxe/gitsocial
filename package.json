{
  "name": "gitsocial",
  "version": "1.0.0",
  "description": "iOS dark-themed social media platform using Catbox.moe for media storage",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "dev": "node server.js",
    "dev:cf": "npx wrangler pages dev public/ --d1 DB --persist-to .wrangler/state --port 3000",
    "db:setup:local": "npx wrangler d1 execute DB --local --file=schema.sql",
    "db:setup:remote": "npx wrangler d1 execute gitsocial_db --remote --file=schema.sql",
    "deploy:cf": "npx wrangler pages deploy public/",
    "deploy:vercel": "vercel deploy"
  },
  "dependencies": {
    "@vercel/kv": "^3.0.0",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "wrangler": "^3.0.0"
  },
  "keywords": [
    "social-media",
    "catbox",
    "cloudflare-workers",
    "vercel",
    "ios-theme"
  ],
  "author": "nonxe",
  "license": "MIT"
}
